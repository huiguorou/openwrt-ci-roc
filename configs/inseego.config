# =========================================================
# 1. 目标平台与机型声明 (精确适配 qualcommax 框架)
# =========================================================
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq807x=y
CONFIG_TARGET_DEVICE_qualcommax_ipq807x_DEVICE_inseego_fg2000=y

# =========================================================
# 2. 核心底层：满血开启 NSS 硬件加速
# =========================================================
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
CONFIG_PACKAGE_kmod-shortcut-fe=y

# =========================================================
# 3. 物理超度：彻底剔除 Wi-Fi 协议栈与高通无线驱动
# =========================================================
# CONFIG_PACKAGE_hostapd is not set
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set
# CONFIG_PACKAGE_wpad-basic-wolfssl is not set
# CONFIG_PACKAGE_kmod-mac80211 is not set
# CONFIG_PACKAGE_kmod-ath11k is not set
# CONFIG_PACKAGE_kmod-ath11k-ahb is not set
# CONFIG_PACKAGE_kmod-ath11k-pci is not set
# CONFIG_PACKAGE_kmod-ath is not set

# =========================================================
# 4. 物理超度：彻底剔除 5G 蜂窝基带驱动与拨号管理
# =========================================================
# CONFIG_PACKAGE_ModemManager is not set
# CONFIG_PACKAGE_luci-proto-modemmanager is not set
# CONFIG_PACKAGE_uqmi is not set
# CONFIG_PACKAGE_umbim is not set
# CONFIG_PACKAGE_kmod-usb-net-qmi-wwan is not set
# CONFIG_PACKAGE_kmod-usb-net-cdc-mbim is not set
# CONFIG_PACKAGE_kmod-usb-serial-option is not set
# CONFIG_PACKAGE_kmod-mhi-net is not set
# CONFIG_PACKAGE_kmod-mhi-pci-generic is not set

# =========================================================
# 5. 基础网络依赖与透明代理底层支撑 (配合 Nikki)
# =========================================================
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_libncurses=y
CONFIG_PACKAGE_kmod-dummy=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y

# =========================================================
# 6. 核心上层插件 (对应你在 Jacob-script.sh 中引入的包)
# =========================================================
# 代理核心与 UI
CONFIG_PACKAGE_nikki=y
CONFIG_PACKAGE_luci-app-nikki=y

# 基础工具与内网穿透
CONFIG_PACKAGE_luci-app-aria2=y
CONFIG_PACKAGE_luci-app-frpc=y
CONFIG_PACKAGE_luci-app-frps=y
CONFIG_PACKAGE_nginx=y
CONFIG_PACKAGE_luci-app-nginx-pingos=y

# 进阶功能插件
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_luci-app-openlist2=y
CONFIG_PACKAGE_luci-app-gecoosac=y
# CONFIG_PACKAGE_luci-app-oaf=y  # OpenAppFilter，如果需要开启去掉前面的 #

# =========================================================
# 7. 界面主题配置
# =========================================================
CONFIG_PACKAGE_luci-theme-aurora=y
CONFIG_PACKAGE_luci-app-aurora-config=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
